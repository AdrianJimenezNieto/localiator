// Esquema Prisma de Localiator.
// Los modelos de dominio (Usuario, Producto, Lote, Pedido, etc.) se añaden en la Fase 1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Roles que SÍ se persisten en BD. Ojo con la asimetría: `packages/shared`
// define además `guest`, pero `guest` no es una fila — es la ausencia de un
// usuario autenticado. Por eso aquí solo existen BUYER y ADMIN.
enum Role {
  BUYER
  ADMIN
}

model User {
  id String @id @default(cuid()) // cuid: no revela el volumen de usuarios (a diferencia de un autoincremental) y es ordenable.

  email           String    @unique
  emailVerifiedAt DateTime? // null = email aún no verificado.
  passwordHash    String? // nullable: un usuario de Google puede no tener contraseña local.
  role            Role      @default(BUYER)

  // Derecho al olvido (RGPD, Fase 4 tarea 02): no se puede borrar la fila de un
  // usuario con facturas (deber de conservación fiscal), así que se ANONIMIZA:
  // email/contraseña se sustituyen por valores neutros y se marca aquí la fecha.
  // Un valor no nulo significa "cuenta anonimizada": no puede volver a iniciar
  // sesión y sus facturas se conservan.
  anonymizedAt DateTime?

  // Ban automático por impago de una subasta ganada (Fase 5, tarea 07). Flag
  // global simple para el MVP: un usuario baneado no puede volver a pujar (lo
  // comprueba placeBid con BidRejectReason.BANNED). `bannedAt`/`banReason` son la
  // propia traza de auditoría de la acción (cuándo y por qué); no hay desban por
  // ahora. Si en el futuro hiciera falta granularidad (histórico, desbanes), se
  // migra a una tabla de bans.
  bannedAt  DateTime?
  banReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs          AuditLog[]
  verificationTokens VerificationToken[]
  oauthAccounts      OAuthAccount[]
  refreshTokens      RefreshToken[]
  orders             Order[]
  bids               Bid[]
  wonAuctions        Auction[]
}

// Sesión persistente (patrón decidido en CLAUDE.md): el access token (JWT corto)
// vive en memoria en el cliente; este refresh token (opaco, de vida larga) viaja
// en una cookie HttpOnly y se guarda AQUÍ para poder revocarlo.
//
// ¿Por qué opaco en BD y no un JWT autocontenido? Porque un JWT no se puede
// invalidar antes de que caduque; guardarlo en BD permite logout real, ban y
// detección de reutilización (rotación). Igual que los otros tokens, guardamos
// SOLO el hash.
model RefreshToken {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String @unique // SHA-256 del token opaco.

  // Rotación: al usar un refresh se revoca y se emite otro. Si más tarde llega un
  // token ya revocado, es señal de robo → se corta toda la cadena de sesión.
  revokedAt         DateTime?
  replacedByTokenId String? // id del token que lo sustituyó (traza de la rotación).

  expiresAt DateTime // sliding expiration (~15 días); se renueva en cada rotación (tarea 10).

  // Metadatos opcionales para auditoría de sesiones.
  userAgent String?
  ip        String?

  createdAt DateTime @default(now())

  @@index([userId])
}

// Vincula una identidad de un proveedor externo (Google, y en el futuro otros) a
// un User local. Tabla genérica en vez de columnas googleId/githubId en User: así
// añadir un proveedor no toca el modelo User ni requiere una migración disruptiva
// (deja la puerta abierta como pide CLAUDE.md).
//
// La unicidad (provider, providerAccountId) garantiza que una misma cuenta de
// Google no se vincule a dos usuarios distintos.
model OAuthAccount {
  id String @id @default(cuid())

  provider          String // "google" (minúscula, estable).
  providerAccountId String // el `sub` de Google: id único e inmutable del usuario.

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Tokens de un solo uso para verificación de email (06) y, más adelante,
// recuperación de contraseña (11). Una sola tabla con `type` en vez de una por
// caso: evita duplicar la mecánica (generar → hashear → validar → invalidar).
//
// SEGURIDAD: guardamos SOLO el hash del token (tokenHash), nunca el token en
// claro, igual que una contraseña. Si se filtra la BD, los tokens no son usables
// porque el enlace lleva el token original y aquí solo vive su hash.
enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      VerificationTokenType
  tokenHash String                @unique // SHA-256 del token; se busca por aquí.

  expiresAt DateTime // caducidad corta (email 24 h, reset 1 h).
  usedAt    DateTime? // un solo uso: al verificar se marca y ya no vale.

  createdAt DateTime @default(now())

  @@index([userId, type])
}

// Estado real del artículo. Muchos vienen de subastas con desperfectos, así que
// la condición es un criterio de filtrado clave del catálogo (ver CLAUDE.md).
enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  DAMAGED
}

// Producto individual y Lote son entidades SEPARADAS e independientes: comparten
// forma (mismos atributos) pero NO hay relación de contención (un lote no contiene
// productos). Se duplica el esquema a propósito para que puedan diverger en el
// futuro sin una migración dolorosa.

// Base de la búsqueda y el filtrado del catálogo. `parentId` es una auto-relación
// opcional: deja la puerta abierta a subcategorías con coste casi nulo, pero si al
// final las categorías son planas, queda siempre null y no estorba.
model Category {
  id String @id @default(cuid())

  name String
  slug String @unique // URLs amigables y SEO (ver Fase 5).

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products Product[]
  lots     Lot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id String @id @default(cuid())

  name        String
  description String
  condition   ItemCondition

  // Dinero en céntimos (Int), nunca Float: la aritmética con enteros evita los
  // errores de coma flotante al operar con euros.
  priceCents    Int
  discountCents Int @default(0)

  stock Int @default(0)

  // URLs de las fotos. La subida real es Fase 3; de momento un array escalar basta.
  photos String[]

  // Obligatoria: todo producto debe ser filtrable por categoría desde el alta.
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model Lot {
  id String @id @default(cuid())

  name        String
  description String
  condition   ItemCondition

  priceCents    Int
  discountCents Int @default(0)

  stock Int @default(0)

  photos String[]

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

// Auditoría de cambios sensibles (precio y stock), exigida por CLAUDE.md. No es
// histórico de precios como funcionalidad de negocio (descartado) — es una traza
// de quién cambió qué y cuándo.
enum AuditEntity {
  PRODUCT
  LOT
}

enum AuditField {
  PRICE
  STOCK
  DISCOUNT
}

// Tabla genérica en vez de una por entidad/atributo: más flexible a cambio de
// perder integridad referencial fuerte en entityId (no es FK real, solo un id
// lógico de Product o Lot según entityType).
//
// IMPORTANTE (Fase 3): la inserción de un AuditLog debe hacerse en la MISMA
// transacción Prisma que el cambio de precio/stock que registra, para que
// ambos se confirmen o fallen juntos (atomicidad).
model AuditLog {
  id String @id @default(cuid())

  // Nullable: sobrevive al borrado del usuario (derecho al olvido RGPD) y permite
  // cambios hechos por procesos automáticos sin actor humano.
  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id])

  entityType AuditEntity
  entityId   String

  field    AuditField
  oldValue Int?
  newValue Int?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
}

// ---------------------------------------------------------------------------
// Pedidos (Fase 3). Flujo de RECOGIDA EN ALMACÉN (sin envíos, ver CLAUDE.md):
// el pedido se paga y luego se prepara y se recoge físicamente; no hay tracking
// ni transportista.
// ---------------------------------------------------------------------------

// Máquina de estados del pedido. El orden refleja el ciclo de vida real:
//   PENDING  → recién creado, con stock reservado, esperando el pago (tarea 03).
//   PAID     → el webhook de Stripe confirmó el cobro; stock ya descontado (06).
//   READY_FOR_PICKUP → el admin lo preparó en el almacén (tarea 11).
//   PICKED_UP → entregado al cliente en el almacén (tarea 11).
//   CANCELLED → reserva expirada/pago fallido, o cancelación de admin (07/11).
// Las transiciones legales se validan en el servicio (tarea 11), no aquí.
enum OrderStatus {
  PENDING
  PAID
  READY_FOR_PICKUP
  PICKED_UP
  CANCELLED
}

// Producto y Lote son entidades SEPARADAS (CLAUDE.md), sin una FK común. Una
// línea de pedido apunta a una u otra con este discriminador + `itemId`, en vez
// de dos FKs medio vacías. La contrapartida: Prisma no fuerza la integridad de
// `itemId`; se valida en el servicio al crear el pedido.
enum OrderItemType {
  PRODUCT
  LOT
}

model Order {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  status OrderStatus @default(PENDING)

  // Total en céntimos (Int), como el resto del dinero del proyecto: lo fija el
  // servidor releyendo el precio de BD, nunca el cliente (seguridad, tarea 03).
  totalCents Int
  currency   String @default("eur")

  // Enlace fuerte con el cobro de Stripe. @unique hace de clave de idempotencia
  // del webhook (tarea 06: un mismo PaymentIntent no confirma el pedido dos
  // veces) y de base para la conciliación (tarea 08). Nullable porque el pedido
  // nace antes de crear el intent de pago (tarea 04).
  stripePaymentIntentId String? @unique

  paidAt DateTime? // se rellena al confirmar el cobro (tarea 06).

  // Origen SUBASTA (tarea 09): si el pedido nace de ganar una subasta, apunta a
  // ella. Nullable: los pedidos de venta directa no la tienen. NO es @unique a
  // propósito: en la segunda oportunidad (tarea 07) se crea un pedido nuevo para el
  // MISMO auctionId (el del moroso queda CANCELLED). Marca el origen para la
  // conciliación y permite saltarse la reserva de stock en el cobro (el ganador ya
  // es el único con derecho al artículo; no pasa por carrito).
  auctionId String?
  auction   Auction? @relation(fields: [auctionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines        OrderLine[]
  reservations StockReservation[]
  invoice      Invoice?

  @@index([userId])
  @@index([status])
  @@index([auctionId])
}

// Copia DESNORMALIZADA (snapshot) del artículo en el momento de la compra. Se
// guarda el nombre y el precio de entonces porque el producto puede editarse o
// borrarse después y el pedido debe seguir siendo fiel a lo que se compró.
// Referenciar solo `itemId` dejaría pedidos "rotos" al cambiar el catálogo.
model OrderLine {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemType OrderItemType
  itemId   String // id lógico del Product/Lot (no es FK real; ver enum).

  nameSnapshot   String // nombre del artículo cuando se compró.
  unitPriceCents Int // precio unitario aplicado (con descuento ya incluido).
  quantity       Int
  lineTotalCents Int // unitPriceCents * quantity, materializado para el histórico.

  @@index([orderId])
}

// Reserva temporal de stock durante el checkout. Es lo que impide vender dos
// veces el mismo artículo mientras un cliente paga (tarea 03). El stock real de
// Product/Lot NO se descuenta aquí: el "disponible" se calcula como
// stock − reservas vivas, así una reserva que expira o un pago fallido liberan
// stock sin tener que "devolverlo" (tareas 03/06/07). El barrido de expiradas
// vive en la tarea 07.
model StockReservation {
  id String @id @default(cuid())

  itemType OrderItemType
  itemId   String
  quantity Int

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  expiresAt DateTime // now + N min al crear la reserva (tarea 03).
  createdAt DateTime @default(now())

  @@index([itemType, itemId])
  @@index([expiresAt])
  @@index([orderId])
}

// Factura de un pedido pagado (tarea 09). Se genera automáticamente al confirmar
// el cobro (webhook, tarea 06). Los precios del catálogo son IVA INCLUIDO, así que
// el desglose va "hacia atrás": grossCents = total del pedido; netCents = base
// imponible; vatCents = grossCents − netCents.
model Invoice {
  id String @id @default(cuid())

  orderId String @unique // un pedido, una factura (idempotencia de la generación).
  order   Order  @relation(fields: [orderId], references: [id])

  // Serie legal correlativa sin huecos (p. ej. "2026-000123"). El número lo asigna
  // un contador atómico por año (InvoiceCounter): requisito legal.
  number   String   @unique
  issuedAt DateTime @default(now())

  // Dinero en céntimos (Int), como el resto del proyecto. vatRateBps = tipo de IVA
  // en puntos básicos (2100 = 21 %): entero, sin decimales flotantes en impuestos.
  netCents   Int
  vatRateBps Int
  vatCents   Int
  grossCents Int

  // Snapshot mínimo del cliente (el emisor es constante y se lee de configuración
  // al renderizar). El email puede cambiar/borrarse después; la factura no.
  customerEmail String

  createdAt DateTime @default(now())
}

// Contador correlativo de facturas por año. Fila por año; el número se incrementa
// de forma atómica (INSERT ... ON CONFLICT DO UPDATE ... RETURNING) para que dos
// facturas simultáneas no se salten ni repitan número (sin huecos, requisito
// legal). Tabla propia en vez de contar filas de Invoice: evita carreras.
model InvoiceCounter {
  year       Int @id
  lastNumber Int @default(0)
}

// ---------------------------------------------------------------------------
// Subastas propias (Fase 5). Una subasta pone a pujar UN artículo (producto o
// lote) del catálogo durante una ventana de tiempo. El cobro del ganador
// (tarea 09) reutiliza el flujo de pedidos/Stripe de la Fase 3: una subasta
// ganada acaba siendo un Order normal, indistinguible de una venta directa.
// ---------------------------------------------------------------------------

// Ciclo de vida de la subasta. El orden refleja el flujo real:
//   SCHEDULED → creada, aún no ha llegado su `startsAt`.
//   LIVE      → abierta, admite pujas entre `startsAt` y `endsAt` (tarea 02).
//   CLOSED    → venció `endsAt`; ganador fijado o desierta (tarea 06).
//   PAID      → el ganador pagó por el flujo Stripe existente (tarea 09).
//   CANCELLED → cancelada, o desierta sin más pujadores tras impago (tarea 07).
// Las transiciones legales se validan en el servicio, no aquí (como OrderStatus).
enum AuctionStatus {
  SCHEDULED
  LIVE
  CLOSED
  PAID
  CANCELLED
}

// El artículo subastado es un Product o un Lot, entidades SEPARADAS sin FK común
// (CLAUDE.md). Se reutiliza `OrderItemType` como discriminador en vez de crear un
// enum propio: los valores son los mismos (PRODUCT/LOT) y significan lo mismo.
// Como en OrderLine, `itemId` NO es una FK real; se valida en el servicio.
model Auction {
  id String @id @default(cuid())

  itemType OrderItemType
  itemId   String // id lógico del Product/Lot (no es FK real; ver enum).

  // Dinero en céntimos (Int), como todo el dinero del proyecto. Precio de salida
  // y salto mínimo entre pujas; el incremento es fijo por subasta (tarea 02).
  startingPriceCents Int
  minIncrementCents  Int

  startsAt DateTime
  // Columna normal MUTABLE (no calculada): el antisniping (tarea 05) la mueve a
  // `now + 5 min` ante pujas de último segundo, y el cierre (tarea 06) la relee.
  endsAt   DateTime

  status AuctionStatus @default(SCHEDULED)

  // Ganador DESNORMALIZADO: se fija al cerrar (tarea 06) para no recalcular la
  // puja máxima en cada lectura ni en el cobro (tarea 09) / impago (tarea 07).
  // `winningBidId` es @unique: una puja no puede ganar dos subastas.
  winnerUserId String?
  winner       User?   @relation(fields: [winnerUserId], references: [id])
  winningBidId String? @unique

  // Plazo de pago del ganador actual (tarea 07). Se fija al cerrar con ganador
  // (tarea 06) y se REINICIA en cada segunda oportunidad. Un job busca subastas
  // CLOSED con este plazo vencido y sin pago (aún CLOSED, no PAID): banea al
  // moroso y ofrece la subasta al siguiente pujador. Nullable: desierta o aún LIVE.
  paymentDueAt DateTime?

  // Aviso "a punto de cerrar" (tarea 08): marca el instante en que se avisó a los
  // pujadores de que quedaba poco. Guard para no reavisar (una vez por cuenta
  // atrás). El antisniping (tarea 05) lo REINICIA a null al extender `endsAt`, para
  // poder volver a avisar cuando la subasta se acerque de nuevo a su nuevo cierre.
  endingSoonNotifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bids Bid[]

  // Pedidos nacidos de esta subasta (tarea 09). Normalmente uno (el del ganador);
  // pueden ser varios en el tiempo si hubo impago + segunda oportunidad (tarea 07):
  // el del moroso queda CANCELLED y se crea otro para el nuevo ganador.
  orders Order[]

  @@index([status])
  @@index([itemType, itemId])
}

// Una puja de un usuario sobre una subasta. Las pujas son INMUTABLES: el
// "historial de pujas" son todas las filas Bid de una subasta ordenadas por
// `createdAt`, sin necesidad de una tabla de historial aparte. La regla de
// negocio (superar la máxima + incremento) vive en el servicio (tarea 02) y su
// blindaje de concurrencia en la tarea 04.
model Bid {
  id String @id @default(cuid())

  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  amountCents Int

  createdAt DateTime @default(now())

  // Índice compuesto para leer la puja máxima de una subasta rápido
  // (ORDER BY amountCents DESC LIMIT 1).
  @@index([auctionId, amountCents])
}
