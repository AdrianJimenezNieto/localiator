# Copiar a .env y rellenar. NUNCA commitear .env con valores reales.

# ---- PostgreSQL (usado por docker-compose y por Prisma) ----
POSTGRES_USER=localiator
POSTGRES_PASSWORD=changeme
POSTGRES_DB=localiator
POSTGRES_PORT=5432

# ---- Backend (NestJS) ----
NODE_ENV=development
API_PORT=3000
# Nivel de log (trace|debug|info|warn|error|fatal). Por defecto: debug en dev, info en prod.
LOG_LEVEL=
DATABASE_URL=postgresql://localiator:changeme@localhost:5432/localiator?schema=public
# URL pública del frontend; se usa para construir enlaces de los emails (verificación, reseteo).
APP_URL=http://localhost:5173
# Base pública de la web para las URLs del sitemap (tarea 06 SEO). Si se omite, usa APP_URL.
PUBLIC_WEB_URL=http://localhost:5173
# URL pública de la propia API; se usa para construir las URLs de las fotos subidas.
API_PUBLIC_URL=http://localhost:3000

# ---- Subida de fotos ----
# Directorio físico donde se guardan las fotos del catálogo (relativo al cwd de la
# API o ruta absoluta). En producción será un volumen Docker para que persistan.
UPLOAD_DIR=uploads
# Tamaño máximo por archivo, en bytes (5 MB por defecto).
MAX_UPLOAD_BYTES=5000000

# Secretos de sesión (generar valores largos y aleatorios)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Vida del access token (JWT en memoria) y del refresh token (cookie HttpOnly).
# REFRESH_TOKEN_TTL es la ventana de INACTIVIDAD (sliding): cada renovación la
# reinicia, así que la sesión se cierra sola tras 15 días sin usarse.
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=15d

# ---- Servicios externos ----
# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Datos fiscales del emisor para las facturas (tarea 09). Rellenar con los reales
# (ver tasks/manual.md); si faltan se usan placeholders.
INVOICE_ISSUER_NAME="Localiator"
INVOICE_ISSUER_TAX_ID=
INVOICE_ISSUER_ADDRESS=
# Resend (email transaccional). Sin clave, los emails se registran en el log (no se envían).
RESEND_API_KEY=
# Remitente de los emails (dominio verificado en Resend; onboarding@resend.dev vale para pruebas).
MAIL_FROM="Localiator <onboarding@resend.dev>"
# Instrucciones de recogida en almacén (emails y web; sin envíos). Texto libre.
PICKUP_INSTRUCTIONS="Recoge tu pedido en nuestro almacén. Te indicaremos dirección y horario cuando esté listo."
# Cloudflare Turnstile (CAPTCHA)
TURNSTILE_SECRET_KEY=
# OAuth Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ---- Frontend (Vite) ----
VITE_API_URL=http://localhost:3000
VITE_TURNSTILE_SITE_KEY=
