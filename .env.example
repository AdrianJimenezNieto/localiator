# Copiar a .env y rellenar. NUNCA commitear .env con valores reales.

# ---- PostgreSQL (usado por docker-compose y por Prisma) ----
POSTGRES_USER=localiator
POSTGRES_PASSWORD=changeme
POSTGRES_DB=localiator
POSTGRES_PORT=5432

# ---- Backend (NestJS) ----
NODE_ENV=development
API_PORT=3000
DATABASE_URL=postgresql://localiator:changeme@localhost:5432/localiator?schema=public
# URL pública del frontend; se usa para construir enlaces de los emails (verificación, reseteo).
APP_URL=http://localhost:5173

# Secretos de sesión (generar valores largos y aleatorios)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ---- Servicios externos ----
# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Resend (email transaccional). Sin clave, los emails se registran en el log (no se envían).
RESEND_API_KEY=
# Remitente de los emails (dominio verificado en Resend; onboarding@resend.dev vale para pruebas).
MAIL_FROM="Localiator <onboarding@resend.dev>"
# Cloudflare Turnstile (CAPTCHA)
TURNSTILE_SECRET_KEY=
# OAuth Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ---- Frontend (Vite) ----
VITE_API_URL=http://localhost:3000
VITE_TURNSTILE_SITE_KEY=
